flowchart TD
    START([进入 _run_conversation<br/>messages / model / system_prompt / max_tokens]) --> GETTOOLS[获取工具集<br/>_get_tools_with_mcp 含 MCP]
    GETTOOLS --> INIT["turn_counter += 1<br/>step_error_count = 0<br/>consecutive_tool_error_steps = 0"]
    INIT --> CYCLECHK{cycle_config.enabled?}
    CYCLECHK -->|是| ADVCYCLE["_maybe_advance_cycle<br/>输入超阈值→归档旧cycle+裁剪消息<br/>(best-effort, 失败不阻塞)"]
    CYCLECHK -->|否| LATENCY
    ADVCYCLE --> LATENCY["准备延迟追踪<br/>latency_turn_id"]
    LATENCY --> LOOPINIT["tool_round_count = 0<br/>round_idx = 0"]

    LOOPINIT --> LOOPCOND{"round_idx <=<br/>max_tool_round_trips + 1 ?"}
    LOOPCOND -->|否, 跑满| LIMIT
    LOOPCOND -->|是| ROUNDSTART["round_start 日志<br/>开 round_trace"]

    ROUNDSTART --> STEER["① drain_steers 中途插话<br/>遍历未消费的 steer 文本"]
    STEER --> STEEREACH{有 steer 文本?}
    STEEREACH -->|有| STEERPROC["prepare_turn_for_model<br/>append Message.user<br/>observe_references"]
    STEEREACH -->|无| PRECHK
    STEERPROC --> PRECHK

    PRECHK["② 容量预检查<br/>run_pre_request_checkpoint<br/>(必要时 _emergency_compact)"] --> LAYERCHK["_maybe_layered_context_checkpoint"]
    LAYERCHK --> COMPACTCOND{"③ len(messages) > 500<br/>OR should_compact() ?"}
    COMPACTCOND -->|是| DOCOMPACT["compact_messages_safe<br/>messages[:] = 压缩结果"]
    COMPACTCOND -->|否| LSP
    DOCOMPACT --> SUMCOND{有 summary_prompt?}
    SUMCOND -->|有| SUMATTACH["system_prompt += summary<br/>_record_compaction_summary 持久化"]
    SUMCOND -->|无| LSP
    SUMATTACH --> LSP

    LSP["④ _flush_pending_lsp_diagnostics<br/>把上轮 hook 诊断塞进 messages"] --> BUILDREQ["⑤ 构造 MessageRequest<br/>model/messages/system_prompt/tools<br/>max_tokens/temperature/top_p<br/>reasoning_effort/extra_body"]
    BUILDREQ --> LLMCALL["llm_invoke_start 日志<br/>turn_loop.run(...)<br/>流式 emit 文本/思考/工具事件<br/>usage_source('agent_round')"]

    LLMCALL --> CANCELCHK1{result.cancelled?}
    CANCELCHK1 -->|否| EMITROUND["emit AgentRoundCompleteEvent<br/>(round_idx, tool_calls,<br/>preface, thinking)"]
    CANCELCHK1 -->|是| RETCANCEL([return replace result<br/>+ tool_round_count])
    EMITROUND --> TRACEUPD["round_trace.tool_calls 更新"]
    TRACEUPD --> CANCELCHK2{result.cancelled?<br/>二次确认}
    CANCELCHK2 -->|是| RETCANCEL
    CANCELCHK2 -->|否| APPENDMSG

    APPENDMSG{"result.assistant_message<br/>非空?"} -->|是| DOAPPEND["messages.append<br/>(assistant_message)"]
    APPENDMSG -->|否| TOOLCHK
    DOAPPEND --> TOOLCHK

    TOOLCHK{"⑥ 有 tool_calls?"} -->|无| HANDOFF{"_handle_subagent_turn_handoff<br/>(messages) ?"}
    TOOLCHK -->|有| EXECTOOLS
    HANDOFF -->|是, 有子代理交接| NEXTROUND
    HANDOFF -->|否| RETNORMAL([return replace result<br/>+ tool_round_count<br/>★正常结束])

    EXECTOOLS["⑦ tool_round_count += 1<br/>append _build_tool_use_message<br/>_execute_tool_calls 执行工具<br/>messages.extend(tool_results)"] --> COUNTERR["统计 tool_errors<br/>= 含错误块的消息数"]
    COUNTERR --> POSTCHK["⑧ run_post_tool_checkpoint<br/>容量后检查"]
    POSTCHK --> ERRCOND{tool_errors > 0?}
    ERRCOND -->|是| ERRESC["step_error_count += tool_errors<br/>consecutive_tool_error_steps += 1<br/>run_error_escalation_checkpoint"]
    ERRCOND -->|否| ERRRESET["consecutive_tool_error_steps = 0"]
    ERRESC --> PLANCHK
    ERRRESET --> PLANCHK

    PLANCHK{"⑨ tool_errors==0 且<br/>plan模式成功 update_plan?"} -->|是| RETPLAN([return replace result<br/>+ tool_round_count<br/>★Plan停止])
    PLANCHK -->|否| NEXTROUND["round_idx += 1"]
    NEXTROUND --> LOOPCOND

    LIMIT["round_trip_limit_exceeded warning<br/>emit ErrorEvent<br/>'Tool round-trip limit exceeded'"] --> RETLIMIT([return TurnResult<br/>assistant=None, usage=None,<br/>tool_calls=空列表<br/>★超限兜底])

    style RETCANCEL fill:#ffd6d6
    style RETNORMAL fill:#d6f5d6
    style RETPLAN fill:#d6e6ff
    style RETLIMIT fill:#ffe6cc
    style START fill:#e6e6e6
    style LLMCALL fill:#fff2cc
    style EXECTOOLS fill:#fff2cc
